# Browser-safe Convex URL. Used by Vite/React.
VITE_CONVEX_URL=

# Convex HTTP action base URL. Must end in .convex.site.
# Trigger.dev workers use this for callbacks.
CONVEX_SITE_URL=

# Shared secret for Trigger -> Convex callbacks.
# Set the same value in Convex and Trigger.dev.
CONVEX_WORKER_SECRET=

# Trigger.dev project ref. Used by trigger.config.ts and Trigger CLI scripts.
TRIGGER_PROJECT_REF=

# Trigger.dev API secret.
# Required in Convex so Convex can enqueue Trigger runs.
TRIGGER_SECRET_KEY=

# OpenAI key. Set in Trigger.dev worker environment, not Convex.
OPENAI_API_KEY=

# Cloudflare R2. Set these in Convex env, not browser env.
R2_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# Optional public CDN base URL for stable image links.
R2_PUBLIC_BASE_URL=
